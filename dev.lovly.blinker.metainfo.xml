  <project_license>GPL-3.0-only</project_license>
  <name>Blinker</name>
  <summary>Cleaner browsing, sharper focus</summary>

  <description>
    <p>
      Blinker is an opinionated modern browser focused on productivity and privacy. With a clean, minimalistic user interface, it helps you focus on your work and get things done quickly.
    </p>
    <p>Features that make it stand out:</p>
    <ul>
      <li>Clean, collapsible sidebar</li>
      <li>Spaces to organise your work</li>
      <li>Command palette to quickly open a new tab, bookmark, or history</li>
      <li>Supports most streaming services via Widevine</li>
    </ul>
  </description>

  <launchable type="desktop-id">dev.lovly.blinker.desktop</launchable>

  <url type="homepage">https://github.com/lovlygod/Blinker</url>
